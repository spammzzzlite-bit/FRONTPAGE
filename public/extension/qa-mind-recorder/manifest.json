{
  "manifest_version": 3,
  "name": "QA Mind Recorder",
  "version": "2.1.3",
  "description": "Records compact AI-ready QA journeys for test case generation.",
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "scripting",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "QA Mind Recorder"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}